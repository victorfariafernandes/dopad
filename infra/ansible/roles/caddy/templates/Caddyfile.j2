{{ domain }} {
    tls /etc/caddy/certs/origin.pem /etc/caddy/certs/origin.key

    root * /data/frontend
    try_files {path} {path}/index.html {path}.html /index.html
    file_server
}

api.{{ domain }} {
    tls /etc/caddy/certs/origin.pem /etc/caddy/certs/origin.key

    reverse_proxy localhost:8080
}
